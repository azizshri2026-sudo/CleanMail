<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CleanMail.Windows.Views.ComposeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" MaxWidth="800"
          HorizontalAlignment="Stretch">

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="New Message"
                   Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <!-- Fields -->
        <StackPanel Grid.Row="1" Spacing="12">
            <TextBox x:Name="ToField" PlaceholderText="To"
                     Header="To" Text="{x:Bind ViewModel.To, Mode=TwoWay}"/>
            <TextBox x:Name="CcField" PlaceholderText="Cc (optional)"
                     Header="Cc" Text="{x:Bind ViewModel.Cc, Mode=TwoWay}"/>
            <TextBox x:Name="SubjectField" PlaceholderText="Subject"
                     Header="Subject" Text="{x:Bind ViewModel.Subject, Mode=TwoWay}"/>
            <TextBox x:Name="BodyField"
                     Header="Message"
                     Text="{x:Bind ViewModel.Body, Mode=TwoWay}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="300"/>
        </StackPanel>

        <!-- Action bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                    Margin="0,12,0,0" HorizontalAlignment="Right">
            <Button Content="Discard" Click="DiscardButton_Click"/>
            <Button Content="Send" Style="{StaticResource AccentButtonStyle}"
                    Click="SendButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSend, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Page>
