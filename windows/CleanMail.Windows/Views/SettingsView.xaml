<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CleanMail.Windows.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="16" Spacing="16">
        <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}"/>
        <TextBlock Text="Sync interval" Style="{StaticResource BodyStrongTextBlockStyle}"/>
        <ComboBox x:Name="SyncIntervalPicker" SelectedIndex="1">
            <x:String>5 minutes</x:String>
            <x:String>15 minutes</x:String>
            <x:String>30 minutes</x:String>
            <x:String>1 hour</x:String>
        </ComboBox>
    </StackPanel>
</Page>
