<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CleanMail.Windows.Views.InboxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <!-- Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Refresh" Label="Sync" Click="SyncButton_Click"/>
            <AppBarButton Icon="Edit"    Label="Compose" Click="ComposeButton_Click"/>
        </CommandBar>

        <!-- Email list + detail split -->
        <Grid Grid.Row="1" ColumnDefinitions="360,*">
            <ListView x:Name="EmailList"
                      Grid.Column="0"
                      SelectionChanged="EmailList_SelectionChanged"
                      ItemsSource="{x:Bind ViewModel.Emails, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="8,6">
                            <TextBlock Text="{Binding FromDisplay}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{Binding Subject}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding DateDisplay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Detail pane -->
            <ScrollViewer Grid.Column="1" Padding="16">
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
                    <TextBlock Text="{x:Bind ViewModel.SelectedEmail.Subject, Mode=OneWay}"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedEmail.FromDisplay, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedEmail.DateDisplay, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="{StaticResource DividerStrokeColorDefaultBrush}"
                            Padding="0,8,0,0">
                        <TextBlock Text="{x:Bind ViewModel.SelectedEmail.BodyText, Mode=OneWay}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
