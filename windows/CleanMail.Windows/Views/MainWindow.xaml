<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CleanMail.Windows.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:CleanMail.Windows.Views"
    Title="CleanMail">

    <Grid>
        <NavigationView x:Name="NavView"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Inbox" Icon="Mail" Content="Inbox"/>
                <NavigationViewItem Tag="Compose" Icon="Edit" Content="Compose"/>
                <NavigationViewItem Tag="Accounts" Icon="People" Content="Accounts"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
